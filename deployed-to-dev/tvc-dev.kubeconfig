apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: 
    server: https://talos.dev.turnkey.engineering
  name: tk-dev
- cluster:
    certificate-authority-data: 
    server: https://talos.preprod.turnkey.engineering
  name: tk-preprod
- cluster:
    certificate-authority-data: 
    server: https://talos.prod.turnkey.engineering
  name: tk-prod
contexts:
- context:
    cluster: tk-dev
    user: turnkey-developer
  name: tk-dev
- context:
    cluster: tk-preprod
    user: turnkey-developer
  name: tk-preprod
- context:
    cluster: tk-prod
    user: turnkey-developer
  name: tk-prod
current-context: tk-dev
kind: Config
users:
- name: turnkey-developer
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1
      args:
      - kubernetes
      - auth
      command: tkinfra
      env: null
      interactiveMode: Never
      provideClusterInfo: false
